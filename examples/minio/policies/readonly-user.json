{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::real-estate*",
        "arn:aws:s3:::sftp-*",
        "arn:aws:s3:::ga-*",
        "arn:aws:s3:::*"
      ]
    }
  ]
}