module "featureserv" {
  source    = "../../modules/pg_featureserv"
  name      = "featureserv"
  namespace = k8s_core_v1_namespace.this.metadata[0].name
  env_map = {
    DATABASE_URL = "postgresql://postgres:postgres@${module.postgres.name}/postgis"
  }
}

resource "k8s_networking_k8s_io_v1_ingress" "featureserv" {
  metadata {
    annotations = {
      "kubernetes.io/ingress.class"              = "nginx"
      "nginx.ingress.kubernetes.io/server-alias" = "featureserv-${var.namespace}.*"
      "nginx.ingress.kubernetes.io/ssl-redirect" = "true"
    }
    name      = "featureserv-${var.namespace}"
    namespace = k8s_core_v1_namespace.this.metadata[0].name
  }
  spec {
    rules {
      host = "featureserv-${var.namespace}"
      http {
        paths {
          backend {
            service {
              name = module.featureserv.name
              port {
                number = module.featureserv.ports[0].port
              }
            }
          }
          path      = "/"
          path_type = "ImplementationSpecific"
        }
      }
    }
  }
}

