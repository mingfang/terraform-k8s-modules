module "martin" {
  source    = "../../modules/generic-deployment-service"
  name      = "martin"
  namespace = k8s_core_v1_namespace.this.metadata[0].name
  image = "ghcr.io/maplibre/martin:v0.13.0"
  ports = [{name="http", port=3000}]
  env_map = {
    DATABASE_URL = "postgresql://postgres:postgres@${module.postgres.name}/postgis"
  }
}

resource "k8s_networking_k8s_io_v1_ingress" "martin" {
  metadata {
    annotations = {
      "kubernetes.io/ingress.class"              = "nginx"
      "nginx.ingress.kubernetes.io/server-alias" = "martin-${var.namespace}.*"
      "nginx.ingress.kubernetes.io/ssl-redirect" = "true"
    }
    name      = "martin-${var.namespace}"
    namespace = k8s_core_v1_namespace.this.metadata[0].name
  }
  spec {
    rules {
      host = "martin-${var.namespace}"
      http {
        paths {
          backend {
            service {
              name = module.martin.name
              port {
                number = module.martin.ports[0].port
              }
            }
          }
          path      = "/"
          path_type = "ImplementationSpecific"
        }
      }
    }
  }
}
