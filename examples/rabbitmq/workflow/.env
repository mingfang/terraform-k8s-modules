# Auto-generated, please adjust.
# ---------- Database ---------- 
DIRECTOR_DATABASE_URI="cockroachdb://root@cockroachdb.cockroachdb-example.svc.cluster.local:26257/postgres"
DIRECTOR_DATABASE_POOL_RECYCLE=-1


# ---------- Celery ----------
DIRECTOR_BROKER_URI="amqp://guest:guest@rabbitmq.rabbitmq-example.svc.cluster.local:5672"
#DIRECTOR_RESULT_BACKEND_URI="db+cockroachdb://root@cockroachdb.cockroachdb-example.svc.cluster.local:26257/postgres"
DIRECTOR_RESULT_BACKEND_URI="rpc://"


# ---------- Frontend ---------- 
DIRECTOR_API_URL="/api"
DIRECTOR_FLOWER_URL="http://127.0.0.1:5555"
DIRECTOR_ENABLE_HISTORY_MODE=false
DIRECTOR_REFRESH_INTERVAL=30000
DIRECTOR_REPO_LINK="https://github.com/ovh/celery-director"
DIRECTOR_DOCUMENTATION_LINK="https://ovh.github.io/celery-director"


# ---------- API ----------
DIRECTOR_WORKFLOWS_PER_PAGE=1000
DIRECTOR_AUTH_ENABLED = false

# These settings are designed to be used with the "director dlassets" command,
# the DIRECTOR_STATIC_FOLDER will be used if you set DIRECTOR_ENABLE_CDN to false.
DIRECTOR_ENABLE_CDN=true
DIRECTOR_STATIC_FOLDER=${DIRECTOR_HOME}/static

# ---------- Sentry ----------
DIRECTOR_SENTRY_DSN=""

# ---------- Retention ----------
DIRECTOR_DEFAULT_RETENTION_OFFSET=1000
